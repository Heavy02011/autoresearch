# Docker ignore for autoresearch build context
# Exclude large/unnecessary files from Docker build

# Run artifacts
runs/
logs/
*.log

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments
.venv/
venv/
env/

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# Version control
.git/
.gitignore

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Notebooks (not needed in container)
*.ipynb
.ipynb_checkpoints/

# Documentation
docs/
*.md
!README.md

# Simulator binary (mounted as volume)
*.x86_64
*.exe
sdsandbox/

# Secrets / env files (never bake credentials into image)
.env
.env.*
*.pem
*.key
